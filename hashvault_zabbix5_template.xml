                </item>
                <item>
                    <name>Balance: Unconfirmed Collective</name>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.unconfirmedBalance.collective.total]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <applications>
                        <application><name>HashVault: Revenue</name></application>
                    </applications>
                </item>
                <item>
                    <name>Total Paid (XMR)</name>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.totalPaidXMR]</key>
                    <delay>3600s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <applications>
                        <application><name>HashVault: Revenue</name></application>
                    </applications>
                </item>
                <item>
                    <name>Daily Credited (XMR)</name>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.dailyCreditedXMR]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <applications>
                        <application><name>HashVault: Revenue</name></application>
                    </applications>
                </item>
                <item>
                    <name>Payout Threshold (XMR)</name>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.payoutThresholdXMR]</key>
                    <delay>3600s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <applications>
                        <application><name>HashVault: Revenue</name></application>
                    </applications>
                </item>
                <item>
