                    <applications>
                        <application><name>HashVault: Mining</name></application>
                    </applications>
                </item>
                <item>
                    <name>Balance: Confirmed (XMR)</name>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.confirmedBalanceXMR]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
