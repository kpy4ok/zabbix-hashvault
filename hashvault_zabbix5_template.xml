<?xml version="1.0" encoding="UTF-8"?>
<zabbix_export>
    <version>5.0</version>
    <date>2026-03-12T12:00:00Z</date>
    <groups>
        <group>
            <n>Templates/Applications</n>
        </group>
    </groups>
    <templates>
        <template>
            <template>HashVault Mining Pool</template>
            <n>HashVault Mining Pool Monitor</n>
            <description>Monitors Monero mining stats via HashVault API. Set {$WALLET_ADDRESS} macro on the host.</description>
            <groups>
                <group>
                    <n>Templates/Applications</n>
                </group>
            </groups>
            <applications>
                <application>
                    <n>HashVault: Hashrate</n>
                </application>
                <application>
                    <n>HashVault: Shares</n>
                </application>
                <application>
                    <n>HashVault: Mining</n>
                </application>
                <application>
                    <n>HashVault: Revenue</n>
                </application>
                <application>
                    <n>HashVault: Aux</n>
                </application>
            </applications>
            <macros>
                <macro>
                    <macro>{$WALLET_ADDRESS}</macro>
                    <value>YOUR_WALLET_ADDRESS_HERE</value>
                    <description>Monero wallet address for HashVault</description>
                </macro>
                <macro>
                    <macro>{$HASHRATE_WARN_DROP_PCT}</macro>
                    <value>50</value>
                    <description>Hashrate drop % threshold for warning trigger</description>
                </macro>
                <macro>
                    <macro>{$STALE_SHARES_WARN_PCT}</macro>
                    <value>5</value>
                    <description>Stale shares % threshold for warning trigger</description>
                </macro>
                <macro>
                    <macro>{$NO_SHARE_TIMEOUT}</macro>
                    <value>600</value>
                    <description>Seconds without shares before HIGH alert</description>
                </macro>
            </macros>
            <items>
                <!-- ==================== HASHRATE ==================== -->
                <item>
                    <n>Hashrate: Current</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <description>Current collective hashrate</description>
                    <applications>
                        <application><n>HashVault: Hashrate</n></application>
                    </applications>
                </item>
                <item>
                    <n>Hashrate: 1h Average</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.avg1hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <description>1-hour average hashrate</description>
                    <applications>
                        <application><n>HashVault: Hashrate</n></application>
                    </applications>
                </item>
                <item>
                    <n>Hashrate: 3h Average</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.avg3hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <description>3-hour average hashrate</description>
                    <applications>
                        <application><n>HashVault: Hashrate</n></application>
                    </applications>
                </item>
                <item>
                    <n>Hashrate: 6h Average</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.avg6hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <description>6-hour average hashrate</description>
                    <applications>
                        <application><n>HashVault: Hashrate</n></application>
                    </applications>
                </item>
                <item>
                    <n>Hashrate: 24h Average</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.avg24hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <description>24-hour average hashrate</description>
                    <applications>
                        <application><n>HashVault: Hashrate</n></application>
                    </applications>
                </item>
                <!-- ==================== SHARES ==================== -->
                <item>
                    <n>Shares: Valid</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.validShares]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Total valid shares</description>
                    <applications>
                        <application><n>HashVault: Shares</n></application>
                    </applications>
                </item>
                <item>
                    <n>Shares: Invalid</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.invalidShares]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Total invalid shares</description>
                    <applications>
                        <application><n>HashVault: Shares</n></application>
                    </applications>
                </item>
                <item>
                    <n>Shares: Stale</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.staleShares]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Total stale shares</description>
                    <applications>
                        <application><n>HashVault: Shares</n></application>
                    </applications>
                </item>
                <item>
                    <n>Shares: Stale Percentage</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.staleSharesPct]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>%</units>
                    <description>Stale shares as percentage of valid shares</description>
                    <applications>
                        <application><n>HashVault: Shares</n></application>
                    </applications>
                </item>
                <item>
                    <n>Shares: Rate (per 30s)</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.shareRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <description>Shares submitted per 30 seconds</description>
                    <applications>
                        <application><n>HashVault: Shares</n></application>
                    </applications>
                </item>
                <item>
                    <n>Last Share Timestamp</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.lastShare]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>unixtime</units>
                    <description>Timestamp of last share (ms since epoch)</description>
                    <applications>
                        <application><n>HashVault: Shares</n></application>
                    </applications>
                </item>
                <!-- ==================== HASHES & BLOCKS ==================== -->
                <item>
                    <n>Round Hashes</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.roundHashes]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Hashes in current round</description>
                    <applications>
                        <application><n>HashVault: Mining</n></application>
                    </applications>
                </item>
                <item>
                    <n>Total Hashes</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.totalHashes]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Total hashes submitted all-time</description>
                    <applications>
                        <application><n>HashVault: Mining</n></application>
                    </applications>
                </item>
                <item>
                    <n>Blocks Found</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.foundBlocks]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Total blocks found</description>
                    <applications>
                        <application><n>HashVault: Mining</n></application>
                    </applications>
                </item>
                <item>
                    <n>Current Effort</n>
                    <key>hashvault[{$WALLET_ADDRESS},collective.currentEffort]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>%</units>
                    <description>Current mining effort percentage</description>
                    <applications>
                        <application><n>HashVault: Mining</n></application>
                    </applications>
                </item>
                <!-- ==================== REVENUE ==================== -->
                <item>
                    <n>Balance: Confirmed (XMR)</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.confirmedBalanceXMR]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <description>Confirmed balance in XMR</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Balance: Confirmed (atomic)</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.confirmedBalance]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Confirmed balance in atomic units</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Balance: Unconfirmed Collective</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.unconfirmedBalance.collective.total]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Unconfirmed collective balance (atomic)</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Total Paid (XMR)</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.totalPaidXMR]</key>
                    <delay>3600s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <description>Total XMR paid out all-time</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Daily Credited (XMR)</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.dailyCreditedXMR]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <description>XMR credited in last 24 hours</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Payout Threshold (XMR)</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.payoutThresholdXMR]</key>
                    <delay>3600s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>0</value_type>
                    <units>XMR</units>
                    <description>Configured payout threshold</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Total Payments Sent</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.totalPaymentsSent]</key>
                    <delay>3600s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Number of payouts sent</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <item>
                    <n>Total Rewards Credited</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.totalRewardsCredited]</key>
                    <delay>3600s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Number of rewards credited</description>
                    <applications>
                        <application><n>HashVault: Revenue</n></application>
                    </applications>
                </item>
                <!-- ==================== AUX ==================== -->
                <item>
                    <n>Aux: Confirmed Balance (atomic)</n>
                    <key>hashvault[{$WALLET_ADDRESS},revenue.auxConfirmedBalance]</key>
                    <delay>300s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <description>Merge-mined coin confirmed balance</description>
                    <applications>
                        <application><n>HashVault: Aux</n></application>
                    </applications>
                </item>
            </items>
            <!-- ==================== TRIGGERS ==================== -->
            <triggers>
                <trigger>
                    <expression>{HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.hashRate].last()}=0</expression>
                    <n>Hashrate is ZERO - all miners down</n>
                    <priority>4</priority>
                    <description>Current hashrate dropped to zero. All miners may be offline.</description>
                </trigger>
                <trigger>
                    <expression>{HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.avg1hashRate].last()}&lt;({HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.avg24hashRate].last()}*(100-{$HASHRATE_WARN_DROP_PCT})/100)</expression>
                    <n>Hashrate dropped &gt;{$HASHRATE_WARN_DROP_PCT}% vs 24h average</n>
                    <priority>2</priority>
                    <description>1-hour average hashrate has dropped significantly compared to the 24-hour average.</description>
                </trigger>
                <trigger>
                    <expression>{HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.staleSharesPct].last()}&gt;{$STALE_SHARES_WARN_PCT}</expression>
                    <n>Stale shares &gt;{$STALE_SHARES_WARN_PCT}%</n>
                    <priority>2</priority>
                    <description>High stale share rate may indicate network latency issues.</description>
                </trigger>
                <trigger>
                    <expression>{HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.invalidShares].last()}&gt;0 and {HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.invalidShares].change()}&gt;0</expression>
                    <n>Invalid shares increasing</n>
                    <priority>2</priority>
                    <description>Invalid share count is growing. Check miner configuration.</description>
                </trigger>
                <trigger>
                    <expression>(now()-{HashVault Mining Pool:hashvault[{$WALLET_ADDRESS},collective.lastShare].last()}/1000)&gt;{$NO_SHARE_TIMEOUT}</expression>
                    <n>No shares submitted for &gt;{$NO_SHARE_TIMEOUT}s</n>
                    <priority>4</priority>
                    <description>No shares received recently. Miners may be disconnected.</description>
                </trigger>
            </triggers>
            <!-- ==================== GRAPHS ==================== -->
            <graphs>
                <graph>
                    <n>Hashrate Overview</n>
                    <graph_items>
                        <graph_item>
                            <sortorder>0</sortorder>
                            <color>00AA00</color>
                            <item>
                                <host>HashVault Mining Pool</host>
                                <key>hashvault[{$WALLET_ADDRESS},collective.hashRate]</key>
                            </item>
                        </graph_item>
                        <graph_item>
                            <sortorder>1</sortorder>
