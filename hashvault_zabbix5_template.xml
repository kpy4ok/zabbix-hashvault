<?xml version="1.0" encoding="UTF-8"?>
<zabbix_export>
    <version>4.0</version>
    <date>2026-03-12T12:00:00Z</date>
    <groups>
        <group>
            <name>Templates</name>
        </group>
    </groups>
    <templates>
        <template>
            <template>HashVault Mining Pool</template>
            <name>HashVault Mining Pool Monitor</name>
            <description>Monitors Monero mining stats via HashVault API. Set {$WALLET_ADDRESS} macro on the host.</description>
            <groups>
                <group>
                    <name>Templates</name>
                </group>
            </groups>
            <applications>
                <application><name>HashVault: Hashrate</name></application>
                <application><name>HashVault: Shares</name></application>
                <application><name>HashVault: Mining</name></application>
                <application><name>HashVault: Revenue</name></application>
                <application><name>HashVault: Aux</name></application>
            </applications>
            <macros>
                <macro>
                    <macro>{$WALLET_ADDRESS}</macro>
                    <value>YOUR_WALLET_ADDRESS_HERE</value>
                </macro>
                <macro>
                    <macro>{$HASHRATE_WARN_DROP_PCT}</macro>
                    <value>50</value>
                </macro>
                <macro>
                    <macro>{$STALE_SHARES_WARN_PCT}</macro>
                    <value>5</value>
                </macro>
                <macro>
                    <macro>{$NO_SHARE_TIMEOUT}</macro>
                    <value>600</value>
                </macro>
            </macros>
            <items>
                <item>
                    <name>Hashrate: Current</name>
                    <key>hashvault[{$WALLET_ADDRESS},collective.hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <applications>
                        <application><name>HashVault: Hashrate</name></application>
                    </applications>
                </item>
                <item>
                    <name>Hashrate: 1h Average</name>
                    <key>hashvault[{$WALLET_ADDRESS},collective.avg1hashRate]</key>
                    <delay>60s</delay>
                    <history>90d</history>
                    <trends>365d</trends>
                    <value_type>3</value_type>
                    <units>H/s</units>
                    <applications>
                        <application><name>HashVault: Hashrate</name></application>
                    </applications>
                </item>
                <item>
                    <name>Hashrate: 3h Average</name>
